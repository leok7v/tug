# Third-party downloads + extracted sources + build artifacts.
# Everything here is reproducible via `make vendors && make build`.
/vendors/

# orchestrator build artifact
/tug
/tug.dSYM/
/generated/
/tug-embedded
/tug-embedded.dSYM/
/tug-embedded-apk
/tug-embedded-apk.dSYM/

# persistent Alpine data disk (large; created by `make disk`)
/tug-data.img
*.img

# Boat app: Xcode build output + staged payload resources (boat.xcodeproj is
# tracked; regenerate with xcodegen / `make -C mac`).
/mac/Build/
/mac/DerivedData/
/mac/payload/
