#!/bin/sh
# tug init (pid 1) for TinyEMU: minimal system bring-up, then an interactive
# shell. Unlike mkroot's default init it does NOT run NTP (TinyEMU has no RTC,
# so the guest clock is epoch 0 and `sntp` would block forever). Networking is
# brought up non-blocking; the cmdline must include virtio_net.napi_tx=false.
#
# Terminal: the host (Terminal.app etc.) IS the VT100/xterm emulator — tug passes
# the guest's escape codes through and reports window size. We export TERM so apps
# assume a real terminal. (A bundled terminfo DB / an in-app emulator for iOS are
# noted in PLAN.md section 5.5.)
export HOME=/home PATH=/bin:/sbin TERM=vt100 PS1='tug:\w\$ '

mountpoint -q dev  || mount -t devtmpfs dev  /dev
mountpoint -q proc || mount -t proc     proc /proc
mountpoint -q sys  || mount -t sysfs    sys  /sys
mkdir -p /dev/pts && { mountpoint -q dev/pts || mount -t devpts dev /dev/pts; }
# (wall clock is set automatically by the kernel from TinyEMU's goldfish RTC)

# Networking: slirp user-mode NAT (guest 10.0.2.15, gateway 10.0.2.2, DNS 10.0.2.3).
# No blocking NTP. resolv.conf points at the slirp resolver so DNS works.
ifconfig lo   127.0.0.1 up        2>/dev/null
ifconfig eth0 10.0.2.15 up        2>/dev/null
route add default gw 10.0.2.2     2>/dev/null
echo 'nameserver 10.0.2.3' > /etc/resolv.conf 2>/dev/null
echo '0 2147483647' > /proc/sys/net/ipv4/ping_group_range 2>/dev/null  # allow ping

cat <<EOF

  tug — riscv64 Linux $(uname -r) on TinyEMU
  try:  uname -a   ls -l /   cat /proc/cpuinfo   ping -c2 8.8.8.8
  keys: Ctrl-C interrupts the guest;  Ctrl-C x3 then again quits tug
  exit: poweroff -f      (or Ctrl-a x to kill the emulator)

EOF

# Prefer bash (readline: arrows, history, tab-completion) if present; toybox sh
# (its pending/ shell) has no line editing, so fall back only if bash is absent.
SH=/bin/sh; [ -x /bin/bash ] && SH=/bin/bash
export SHELL="$SH"

# Interactive shell with a proper controlling terminal on the active console.
setsid -c <>/dev/"$(sed '$s@.*[ /]@@' /sys/class/tty/console/active)" >&0 2>&1 "$SH"
poweroff -f
