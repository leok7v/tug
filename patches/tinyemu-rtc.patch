+/* Goldfish RTC: exposes the host wall clock so the guest sets a real date at boot
+   (TinyEMU has no RTC; otherwise the clock is 1970 and TLS cert checks fail). */
+static uint32_t rtc_read(void *opaque, uint32_t offset, int size_log2)
+{
+    static uint32_t time_high;
+    if (offset == 0x00) { /* TIMER_TIME_LOW: latch now, return low 32 bits of ns */
+        struct timespec ts;
+        uint64_t ns;
+        clock_gettime(CLOCK_REALTIME, &ts);
+        ns = (uint64_t)ts.tv_sec * 1000000000ULL + ts.tv_nsec;
+        time_high = (uint32_t)(ns >> 32);
+        return (uint32_t)ns;
+    } else if (offset == 0x04) { /* TIMER_TIME_HIGH: latched high 32 bits */
+        return time_high;
     }
+    return 0;
+}
+
+static void rtc_write(void *opaque, uint32_t offset, uint32_t val, int size_log2)
+{
+    /* alarm/IRQ registers are unused — we never raise the RTC alarm */
 }
 
